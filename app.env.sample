# PrestaShop — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Admin credentials
APP_ADMIN_USER=admin@example.com
APP_ADMIN_PASS=changeme_admin_password

# Database
DB_CREATE_DATABASE_NAME=prestashop
DB_USER_NAME=prestashop
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Installation options
PS_INSTALL_AUTO=1
PS_DEV_MODE=0
PS_ENABLE_SSL=0
